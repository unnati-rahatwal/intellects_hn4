{
  "name": "accessiq-vscode",
  "displayName": "AccessIQ Remediation Sync",
  "description": "Auto-apply AccessIQ AI-generated accessibility remediations directly in VS Code.",
  "publisher": "intellects",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "accessiq.importReport",
        "title": "AccessIQ: Import Remediation Report"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
