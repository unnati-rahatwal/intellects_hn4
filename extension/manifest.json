{
  "manifest_version": 3,
  "name": "AccessIQ Real-Time Auditor",
  "version": "1.0",
  "description": "Real-time accessibility audits powered by AI.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open AccessIQ"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"]
}
